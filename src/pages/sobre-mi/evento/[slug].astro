---
import PageLayout from '@/layouts/PageLayout.astro';
import Button from '@/components/ui/form/Button/Button.astro';
import Badge from '@/components/ui/data-display/Badge/Badge.astro';
import Card from '@/components/ui/data-display/Card/Card.astro';
import Icon from '@/components/ui/primitives/Icon/Icon.astro';
import { getCollection, render } from 'astro:content';
import { Image } from 'astro:assets';

export async function getStaticPaths() {
  const events = await getCollection('biographyTimeline');
  return events.map((event) => ({
    params: { slug: event.id },
    props: { event },
  }));
}

const { event } = Astro.props;
const { Content } = await render(event);

// Category colors
const categoryColors: Record<string, string> = {
  personal: 'bg-purple-500',
  education: 'bg-blue-500',
  career: 'bg-green-500',
  recognition: 'bg-yellow-500',
  publication: 'bg-orange-500',
};

const categoryLabels: Record<string, string> = {
  personal: 'Personal',
  education: 'Educación',
  career: 'Carrera',
  recognition: 'Reconocimiento',
  publication: 'Publicación',
};

// Get related events (same category or adjacent years)
const allEvents = await getCollection('biographyTimeline');
const relatedEvents = allEvents
  .filter((e) => e.id !== event.id)
  .filter((e) => 
    e.data.category === event.data.category || 
    Math.abs(e.data.year - event.data.year) <= 5
  )
  .slice(0, 3);
---

<PageLayout
  title={`${event.data.title} (${event.data.year}) | Biografía`}
  description={event.data.summary}
>
  <article class="py-12">
    <div class="mx-auto max-w-4xl px-6">
      {/* Breadcrumb */}
      <nav class="flex items-center gap-2 text-sm text-foreground-muted mb-8">
        <a href="/" class="hover:text-brand-500 transition-colors">Inicio</a>
        <Icon name="chevron-right" size="sm" />
        <a href="/sobre-mi" class="hover:text-brand-500 transition-colors">Sobre Mí</a>
        <Icon name="chevron-right" size="sm" />
        <span class="text-foreground">{event.data.title}</span>
      </nav>

      {/* Header */}
      <div class="mb-10" data-reveal>
        <div class="flex flex-wrap items-center gap-3 mb-4">
          <span class={`inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-medium text-white ${categoryColors[event.data.category]}`}>
            <Icon name={event.data.icon} size="sm" />
            {categoryLabels[event.data.category]}
          </span>
          <span class="text-2xl font-bold text-brand-500">{event.data.year}</span>
          {event.data.month && (
            <span class="text-foreground-muted">
              {new Date(event.data.year, event.data.month - 1).toLocaleDateString('es-VE', { month: 'long' })}
            </span>
          )}
        </div>
        
        <h1 class="font-display text-4xl md:text-5xl font-bold text-foreground mb-4">
          {event.data.title}
        </h1>
        
        <p class="text-xl text-foreground-muted">
          {event.data.summary}
        </p>
      </div>

      {/* Featured Image */}
      {event.data.image && (
        <div class="mb-10" data-reveal>
          <div class="relative aspect-video rounded-2xl overflow-hidden bg-background-secondary">
            <Image
              src={event.data.image}
              alt={event.data.title}
              class="w-full h-full object-cover"
              width={800}
              height={450}
            />
          </div>
          <p class="text-sm text-foreground-muted text-center mt-3">
            {event.data.title} - {event.data.year}
          </p>
        </div>
      )}

      {/* Content */}
      <Card variant="elevated" padding="lg" class="mb-10" data-reveal>
        <div class="prose prose-lg dark:prose-invert max-w-none">
          <Content />
        </div>
      </Card>

      {/* Navigation */}
      <div class="flex justify-between items-center mb-16" data-reveal>
        <Button variant="outline" href="/sobre-mi#timeline">
          <Icon name="arrow-left" size="sm" />
          Volver al Timeline
        </Button>
        <Button href="/libro">
          <Icon name="book-open" size="sm" />
          Conocer el Libro
        </Button>
      </div>

      {/* Related Events */}
      {relatedEvents.length > 0 && (
        <div data-reveal>
          <h2 class="font-display text-2xl font-bold text-foreground mb-6">
            Eventos Relacionados
          </h2>
          <div class="grid gap-4 md:grid-cols-3">
            {relatedEvents.map((relatedEvent) => (
              <Card 
                variant="elevated" 
                hover 
                href={`/sobre-mi/evento/${relatedEvent.id}`}
                class="group"
              >
                <div class="flex items-start gap-3">
                  <div class={`w-10 h-10 rounded-lg ${categoryColors[relatedEvent.data.category]} flex items-center justify-center text-white shrink-0`}>
                    <Icon name={relatedEvent.data.icon} size="sm" />
                  </div>
                  <div>
                    <span class="text-xs font-bold text-brand-500">{relatedEvent.data.year}</span>
                    <h3 class="text-sm font-semibold text-foreground group-hover:text-brand-500 transition-colors line-clamp-2">
                      {relatedEvent.data.title}
                    </h3>
                  </div>
                </div>
              </Card>
            ))}
          </div>
        </div>
      )}
    </div>
  </article>
</PageLayout>

<style>
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
