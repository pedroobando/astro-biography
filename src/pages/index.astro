---
import LandingLayout from '@/layouts/LandingLayout.astro';
import { Hero } from '@/components/hero';
import Button from '@/components/ui/form/Button/Button.astro';
import Badge from '@/components/ui/data-display/Badge/Badge.astro';
import Card from '@/components/ui/data-display/Card/Card.astro';
import Icon from '@/components/ui/primitives/Icon/Icon.astro';
import { getCollection } from 'astro:content';
import siteConfig from '@/config/site.config';
import { Image } from 'astro:assets';
import bookCover from '@/assets/book/book-cover.jpg';

const [profile] = await getCollection('biographyProfile');
const [book] = await getCollection('biographyBook');

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => {
    if (a.data.featured !== b.data.featured) return a.data.featured ? -1 : 1;
    return b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf();
  })
  .slice(0, 3);
---

<LandingLayout
  title={`${siteConfig.name} - Pediatra Puericultor | 60 años de trayectoria`}
  description={`Biografía oficial del Dr. Pedro Rafael Medina Millan - ${profile.data.careerStats.yearsOfService} años de trayectoria, ${profile.data.careerStats.childrenAttended.toLocaleString()} niños atendidos. Autor de "${book.data.title}".`}
  image={siteConfig.ogImage}
  includePersonSchema={true}
  includeProfessionalServiceSchema={true}
>
  <!-- Hero Section - Book Focus -->
  <Hero layout="split" size="xl" class="bg-gradient-to-br from-background via-background-secondary to-background" showGlow>
    <Badge slot="badge" variant="brand" pill>Nuevo Lanzamiento</Badge>
    
    <h1 slot="title">
      <span class="text-foreground">Los Médicos del</span><br />
      <span class="text-brand-500">Estado Barinas</span>
    </h1>

    <div slot="description">
      <p class="text-lg text-foreground-muted max-w-xl leading-relaxed">
        Descubre la historia de los médicos que forjaron la medicina en Barinas. 
        Una obra del <strong>Dr. Pedro Rafael Medina Millan</strong> que preserva el legado 
        de quienes dedicaron sus vidas a la salud del pueblo llanero.
      </p>
      
      <div class="flex flex-wrap gap-4 items-center mt-6">
        <span class="text-3xl font-bold text-brand-500">$35 USD</span>
        <span class="text-foreground-muted">·</span>
        <span class="text-foreground-muted">{book.data.pages} páginas</span>
        <span class="text-foreground-muted">·</span>
        <span class="text-foreground-muted">{book.data.coverOptions.join(' o ')}</span>
      </div>

      <p class="text-sm text-foreground-muted mt-4">
        <Icon name="truck" size="sm" class="inline mr-1" />
        Envío disponible a todo Venezuela
      </p>
    </div>

    <Fragment slot="actions">
      <Button size="lg" href="/libro/comprar">
        <Icon name="shopping-cart" size="sm" />
        Comprar Ahora
      </Button>
      <Button size="lg" variant="outline" href="/libro">
        <Icon name="book-open" size="sm" />
        Conocer el Libro
      </Button>
    </Fragment>

    <div slot="aside" class="relative">
      <div class="relative aspect-[3/4] max-w-md mx-auto">
        <div class="absolute inset-0 bg-gradient-to-br from-brand-500/20 to-brand-500/5 rounded-2xl transform rotate-3"></div>
        <Image
          src={bookCover}
          alt={`Portada del libro ${book.data.title}`}
          class="relative rounded-2xl shadow-2xl w-full h-full object-cover"
          width={400}
          height={600}
        />
        <div class="absolute -bottom-4 -right-4 bg-brand-500 text-white rounded-full w-24 h-24 flex flex-col items-center justify-center shadow-lg">
          <span class="text-2xl font-bold">$35</span>
          <span class="text-xs">USD</span>
        </div>
      </div>
    </div>
  </Hero>

  <!-- Stats Section -->
  <section class="relative z-10 py-16 bg-brand-500/5 dark:bg-background-secondary border-y border-border">
    <div class="mx-auto max-w-6xl px-6">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8 text-center">
        <div class="flex flex-col items-center gap-2">
          <span class="text-4xl font-bold text-brand-500" data-countup="87">0</span>
          <span class="text-sm text-foreground-muted">Años de vida</span>
        </div>
        <div class="flex flex-col items-center gap-2">
          <span class="text-4xl font-bold text-brand-500" data-countup="60">0</span>
          <span class="text-sm text-foreground-muted">Años de trayectoria</span>
        </div>
        <div class="flex flex-col items-center gap-2">
          <span class="text-4xl font-bold text-brand-500" data-countup="35000">0</span>
          <span class="text-sm text-foreground-muted">Niños atendidos</span>
        </div>
        <div class="flex flex-col items-center gap-2">
          <span class="text-4xl font-bold text-brand-500" data-countup="240">0</span>
          <span class="text-sm text-foreground-muted">Pediatras formados</span>
        </div>
      </div>
    </div>
  </section>

  <!-- About Section -->
  <section class="relative z-10 py-[var(--space-section-md)] bg-background">
    <div class="mx-auto max-w-6xl px-6">
      <div class="grid gap-12 lg:grid-cols-2 items-center">
        <div class="flex flex-col gap-6" data-reveal>
          <Badge variant="brand" pill class="w-fit">Sobre el Autor</Badge>
          <h2 class="font-display text-3xl md:text-4xl font-bold text-foreground">
            Dr. Pedro Rafael<br />
            <span class="text-brand-500">Medina Millan</span>
          </h2>
          <p class="text-lg text-foreground-muted leading-relaxed">
            Pediatra Puericultor con {profile.data.careerStats.yearsOfService} años de trayectoria. 
            Creador de la primera UCIN en la región centro-oriental de Venezuela, 
            ex-Coordinador Nacional de Neonatología, y formador de más de 240 pediatras.
          </p>
          <p class="text-foreground-muted leading-relaxed">
            Nacido en Barcelona, Estado Anzoátegui, el 15 de noviembre de 1939. 
            Graduado de la UCV en 1976, dedicó su vida a la salud de los niños venezolanos.
          </p>
          <div class="flex flex-col sm:flex-row gap-4">
            <Button variant="outline" href="/sobre-mi">
              Ver Biografía Completa
              <Icon name="arrow-right" size="sm" />
            </Button>
          </div>
        </div>

        <Card variant="elevated" padding="lg" class="h-full" data-reveal data-reveal-delay="1">
          <div class="grid grid-cols-2 gap-4">
            <div class="bg-background-tertiary rounded-xl p-5 flex flex-col items-center justify-center text-center gap-2 border-t-2 border-brand-500/40">
              <Icon name="graduation-cap" class="w-10 h-10 text-brand-500" />
              <p class="text-sm font-semibold text-foreground">UCV 1976</p>
            </div>
            <div class="bg-background-tertiary rounded-xl p-5 flex flex-col items-center justify-center text-center gap-2 border-t-2 border-brand-500/40">
              <Icon name="hospital" class="w-10 h-10 text-brand-500" />
              <p class="text-sm font-semibold text-foreground">Hospital Razetti</p>
            </div>
            <div class="bg-background-tertiary rounded-xl p-5 flex flex-col items-center justify-center text-center gap-2 border-t-2 border-brand-500/40">
              <Icon name="award" class="w-10 h-10 text-brand-500" />
              <p class="text-sm font-semibold text-foreground">Cruz del Congreso</p>
            </div>
            <div class="bg-background-tertiary rounded-xl p-5 flex flex-col items-center justify-center text-center gap-2 border-t-2 border-brand-500/40">
              <Icon name="users" class="w-10 h-10 text-brand-500" />
              <p class="text-sm font-semibold text-foreground">240+ Pediatras</p>
            </div>
          </div>
        </Card>
      </div>
    </div>
  </section>

  <!-- Book Preview Section -->
  <section class="relative z-10 py-[var(--space-section-md)] bg-background-secondary">
    <div class="mx-auto max-w-6xl px-6">
      <div class="flex flex-col items-center gap-4 text-center mb-12" data-reveal>
        <Badge variant="brand" pill>El Libro</Badge>
        <h2 class="font-display text-3xl md:text-4xl font-bold text-foreground">
          Una obra de valor histórico y cultural
        </h2>
        <p class="text-lg text-foreground-muted max-w-2xl">
          {book.data.description}
        </p>
      </div>

      <div class="grid gap-6 md:grid-cols-3" data-reveal data-reveal-delay="1">
        <Card hover padding="lg">
          <div class="flex flex-col items-center text-center gap-4">
            <div class="w-14 h-14 rounded-xl bg-gradient-to-br from-brand-500/20 to-brand-500/5 flex items-center justify-center text-brand-500">
              <Icon name="book" size="lg" />
            </div>
            <h3 class="text-lg font-semibold text-foreground">Contenido Exclusivo</h3>
            <p class="text-sm text-foreground-muted">
              {book.data.pages} páginas con mini-biografías detalladas de médicos barineses 
              que marcaron la historia.
            </p>
          </div>
        </Card>

        <Card hover padding="lg">
          <div class="flex flex-col items-center text-center gap-4">
            <div class="w-14 h-14 rounded-xl bg-gradient-to-br from-brand-500/20 to-brand-500/5 flex items-center justify-center text-brand-500">
              <Icon name="history" size="lg" />
            </div>
            <h3 class="text-lg font-semibold text-foreground">Legado Preservado</h3>
            <p class="text-sm text-foreground-muted">
              Historias de médicos desde el siglo XIX hasta la actualidad, 
              documentadas para las futuras generaciones.
            </p>
          </div>
        </Card>

        <Card hover padding="lg">
          <div class="flex flex-col items-center text-center gap-4">
            <div class="w-14 h-14 rounded-xl bg-gradient-to-br from-brand-500/20 to-brand-500/5 flex items-center justify-center text-brand-500">
              <Icon name="package" size="lg" />
            </div>
            <h3 class="text-lg font-semibold text-foreground">Edición de Colección</h3>
            <p class="text-sm text-foreground-muted">
              Disponible en {book.data.coverOptions.join(' o ')}. 
              Un libro que todo médico e historiador debe tener.
            </p>
          </div>
        </Card>
      </div>

      <div class="text-center mt-10">
        <Button size="lg" href="/libro">
          <Icon name="book-open" size="sm" />
          Ver Detalles del Libro
        </Button>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="relative z-10 py-[var(--space-section-md)] bg-background">
    <div class="mx-auto max-w-4xl px-6 text-center" data-reveal>
      <h2 class="font-display text-4xl font-bold text-foreground mb-4">
        Adquiere tu ejemplar hoy
      </h2>
      <p class="text-lg text-foreground-muted mb-8 max-w-2xl mx-auto">
        Forma parte de la preservación de la historia médica de Venezuela. 
        Cada compra apoya la investigación y documentación de nuestra memoria colectiva.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <Button size="lg" href="/libro/comprar">
          <Icon name="shopping-cart" size="sm" />
          Comprar Ahora - $35 USD
        </Button>
        <Button size="lg" variant="outline" href="/contact">
          <Icon name="message-circle" size="sm" />
          Hacer una Consulta
        </Button>
      </div>
    </div>
  </section>

  <!-- Blog Section -->
  {posts.length > 0 && (
    <section class="relative z-10 py-[var(--space-section-md)] bg-background-secondary border-t border-border">
      <div class="mx-auto max-w-6xl px-6">
        <div class="flex items-end justify-between mb-8" data-reveal>
          <div>
            <Badge variant="brand" pill class="mb-4">Blog</Badge>
            <h2 class="font-display text-3xl font-bold text-foreground">
              Artículos Recientes
            </h2>
          </div>
          <a href="/blog" class="hidden sm:inline-flex items-center gap-1.5 text-sm font-medium text-brand-500 hover:text-brand-600 transition-colors">
            Ver todos
            <Icon name="arrow-right" size="sm" />
          </a>
        </div>

        <div class="grid gap-6 md:grid-cols-3" data-reveal data-reveal-delay="1">
          {posts.map((post) => (
            <Card variant="elevated" hover href={`/blog/${post.id.replace('es/', '')}`} class="group flex flex-col">
              <div class="flex flex-col h-full">
                <div class="mb-3">
                  <span class="text-xs text-foreground-muted">
                    {new Date(post.data.publishedAt).toLocaleDateString('es-VE', { 
                      year: 'numeric', 
                      month: 'long', 
                      day: 'numeric' 
                    })}
                  </span>
                </div>
                <h3 class="text-lg font-semibold text-foreground mb-2 group-hover:text-brand-500 transition-colors">
                  {post.data.title}
                </h3>
                <p class="text-sm text-foreground-muted line-clamp-3 flex-1">
                  {post.data.description}
                </p>
                <div class="mt-4 flex items-center gap-2 text-brand-500 text-sm font-medium">
                  Leer más
                  <Icon name="arrow-right" size="sm" class="group-hover:translate-x-1 transition-transform" />
                </div>
              </div>
            </Card>
          ))}
        </div>
      </div>
    </section>
  )}

  <script>
    function initCountup() {
      const counters = document.querySelectorAll<HTMLElement>('[data-countup]:not([data-countup-init])');
      if (counters.length === 0) return;
      
      const observer = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (!entry.isIntersecting) return;
          observer.unobserve(entry.target);
          
          const el = entry.target as HTMLElement;
          const target = parseInt(el.dataset.countup ?? '0', 10);
          const duration = 1500;
          const start = performance.now();
          
          const tick = (now: number) => {
            const elapsed = now - start;
            const progress = Math.min(elapsed / duration, 1);
            const eased = 1 - Math.pow(1 - progress, 3);
            el.textContent = Math.round(eased * target).toLocaleString();
            if (progress < 1) requestAnimationFrame(tick);
          };
          
          requestAnimationFrame(tick);
        });
      }, { threshold: 0.5 });
      
      counters.forEach((el) => {
        el.dataset.countupInit = 'true';
        observer.observe(el);
      });
    }

    document.addEventListener('astro:page-load', initCountup);
  </script>
</LandingLayout>
